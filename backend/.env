# App
APP_NAME="Musician Storefront"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database
DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=musician_storefront
DB_USERNAME=user
DB_PASSWORD=password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# JWT
JWT_SECRET=super-secret-key-change-me
JWT_EXPIRY=3600

# AWS S3 / MinIO
STORAGE_DRIVER=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=musician-storefront
AWS_S3_ENDPOINT=http://minio:9000
AWS_S3_PATH_STYLE=true
AWS_S3_SIGNED_URL_TTL_SECONDS=600

# Email (SMTP)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.ionos.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Teaser settings
TEASER_ALLOWED_FORMATS=wav,mp3

# Payments
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
CINETPAY_SITE_ID=
CINETPAY_API_KEY=
PAYDUNIA_MASTER_KEY=
PAYDUNIA_PUBLIC_KEY=
PAYDUNIA_PRIVATE_KEY=
PAYDUNIA_TOKEN=
