{
    "name": "lamuse/backend",
    "description": "Musician Storefront API (Slim PHP)",
    "type": "project",
    "require": {
        "php": "^8.2",
        "aws/aws-sdk-php": "^3.281",
        "dompdf/dompdf": "^2.0",
        "illuminate/container": "^10.49",
        "illuminate/database": "^10.0",
        "illuminate/events": "^10.49",
        "phpmailer/phpmailer": "^6.8",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.0",
        "tuupola/slim-jwt-auth": "^3.6",
        "vlucas/phpdotenv": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
